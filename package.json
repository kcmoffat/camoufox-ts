{
  "name": "camoufox-ts",
  "version": "0.5.1",
  "description": "TypeScript port of the Camoufox Python interface",
  "license": "MIT",
  "homepage": "https://camoufox.com/python",
  "repository": {
    "type": "git",
    "url": "https://github.com/daijro/camoufox"
  },
  "keywords": [
    "camoufox",
    "fingerprint",
    "browser",
    "scraping",
    "playwright",
    "firefox"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "camoufox": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "pack:local": "npm run build && tsx scripts/pack-local.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev:cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.4",
    "adm-zip": "^0.5.16",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^13.1.0",
    "env-paths": "^3.0.0",
    "extract-zip": "^2.0.1",
    "fast-xml-parser": "^5.5.12",
    "fingerprint-generator": "^2.1.82",
    "maxmind": "^5.0.6",
    "ora": "^8.2.0",
    "playwright": "^1.59.1",
    "proxy-agent": "^8.0.1",
    "systeminformation": "^5.27.11",
    "ua-parser-js": "^2.0.3",
    "undici": "^7.25.0",
    "which": "^5.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^24.6.0",
    "@types/which": "^3.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
